<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Result</title>

<style>
body {
  margin:0;
  font-family: Arial, sans-serif;
  background:#f5f5f5;
}

.header {
  background:#e30613;
  color:white;
  padding:15px;
  font-size:24px;
  text-align:center;
}

.card {
  background:white;
  max-width:400px;
  margin:30px auto;
  padding:20px;
  border-radius:12px;
  box-shadow:0 10px 30px rgba(0,0,0,0.1);
  text-align:center;
  animation:fadeIn 1s ease;
}

img {
  width:120px;
  height:120px;
  border-radius:50%;
  object-fit:cover;
  margin-bottom:15px;
}

.name {
  font-size:20px;
  font-weight:bold;
}

.score {
  font-size:40px;
  margin:15px 0;
}

.row {
  display:flex;
  justify-content:space-between;
  margin:8px 0;
}

@keyframes fadeIn {
  from {opacity:0; transform:translateY(20px);}
  to {opacity:1;}
}
</style>
</head>

<body>

<div class="header">Test Result</div>

<div class="card">

  <!-- ✅ 这里已经帮你改好了 -->
  <img src="me.jpg">

  <div class="name">Your Name</div>

  <div class="score">6.0</div>

  <div class="row"><span>Listening</span><span>6.0</span></div>
  <div class="row"><span>Reading</span><span>6.0</span></div>
  <div class="row"><span>Writing</span><span>6.0</span></div>
  <div class="row"><span>Speaking</span><span>6.0</span></div>

</div>

</body>
</html>
